# Appwrite Configuration
# Console: https://fra.cloud.appwrite.io/console/project-69a8205200252be60e2c

NEXT_PUBLIC_APPWRITE_PROJECT_ID=69a8205200252be60e2c
NEXT_PUBLIC_APPWRITE_PROJECT_NAME=Silvoraa
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_DATABASE_ID=silvoraa_production
NEXT_PUBLIC_APPWRITE_PRODUCTS_COLLECTION_ID=products
NEXT_PUBLIC_APPWRITE_ORDERS_COLLECTION_ID=orders
NEXT_PUBLIC_APPWRITE_USERS_COLLECTION_ID=profiles
NEXT_PUBLIC_APPWRITE_REVIEWS_COLLECTION_ID=reviews
NEXT_PUBLIC_APPWRITE_BUCKET_ID=images

# Razorpay Configuration (for payments)
# Get these from https://dashboard.razorpay.com/app/keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id

# Google Gemini API (for AI features)
NEXT_PUBLIC_GEMINI_API_KEY=

# Google Analytics 4 Configuration
# Get your Measurement ID from https://analytics.google.com/
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# PostHog Analytics (https://posthog.com)
# Get your API key from Project Settings > API Keys
NEXT_PUBLIC_POSTHOG_API_KEY=

# Sentry Error Monitoring (https://sentry.io)
# Get DSN from Project Settings > Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=

# Microsoft Clarity Analytics (https://clarity.microsoft.com)
# Get Project ID from your Clarity project setup
NEXT_PUBLIC_CLARITY_PROJECT_ID=
